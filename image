<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CSS3 Image Effects</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

    <h1>CSS3 Image Effects Assignment</h1>

    <div class="image-container">
        <h2>Image 1: Example with Shadow</h2>
        <img src="images/image1.jpg" alt="Example Image 1" class="image shadow-effect">

        <h2>Image 2: Example with Gradient</h2>
        <img src="images/image2.jpg" alt="Example Image 2" class="image gradient-effect">

        <h2>Image 3: Example with Filter</h2>
        <img src="images/image3.jpg" alt="Example Image 3" class="image filter-effect">

        <h2>Image 4: Example with Border Radius</h2>
        <img src="images/image4.jpg" alt="Example Image 4" class="image border-radius-effect">

        <h2>Image 5: Example with Blur</h2>
        <img src="images/image5.jpg" alt="Example Image 5" class="image blur-effect">

        <h2>Image 6: Example with Text Shadow</h2>
        <img src="images/image6.jpg" alt="Example Image 6" class="image text-shadow-effect">
    </div>

</body>
</html>
